{
    "name": "Xlpanel",
    "version": "1.2.1",
    "codename": "Hydea-meee",
    "calagopus": {
        "host": "https://panel.example.com",
        "key": "ptla_your_calagopus_or_pterodactyl_api_key_here",
        "api_base": "/api/admin",
        "accept": "application/json"
    },
    "flask": {
        "host": "0.0.0.0",
        "port": 5000,
        "debug": false
    },
    "mail": {
        "smtp": {
            "host": "smtp.gmail.com",
            "port": 465,
            "user": "your_email@gmail.com",
            "password": "your_app_password",
            "_pwdComment": "If you are using gmail, use app password (generate in google account)",
            "from": "Xlpanel <noreply@example.com>",
            "_fromComment": "Use Name <email> format to set sender name."
        },
        "verifyUser": false,
        "_smtpComment": "required"
    },
    "cf_turnstile": {
        "enable": false,
        "site_key": "your_site_key_here",
        "secret_key": "your_secret_key_here"
    },
    "database": "xlpanel.db",
    "db_comment": "Only support sqlite, provide a file name, not a URL.",
    "redis": {
        "enable": false,
        "url": "redis://127.0.0.1:6379/0",
        "prefix": "xlpanel",
        "verify_ttl_seconds": 1800
    },
    "default": {
        "cpu": 150,
        "ram": 2048,
        "disk": 10240,
        "slot": 1,
        "coin": 0
    },
    "eggs_comment": "Required. Auto-detect is disabled. You must configure eggs manually here.",
    "eggs": {
        "java_21": {
            "name": "Minecraft Java 21",
            "info": {
                "egg_uuid": "11111111-2222-3333-4444-555555555555",
                "image": "ghcr.io/pterodactyl/yolks:java_21",
                "startup": "java -Xms128M -Xmx{{SERVER_MEMORY}}M -jar {{SERVER_JARFILE}}",
                "memory_overhead": 0,
                "io_weight": 500,
                "environment": {
                    "SERVER_JARFILE": "server.jar",
                    "MINECRAFT_VERSION": "latest"
                },
                "feature_limits": {
                    "allocations": 0,
                    "databases": 1,
                    "backups": 1,
                    "schedules": 0
                }
            }
        },
        "nodejs": {
            "name": "Node.js App",
            "info": {
                "egg_uuid": "22222222-3333-4444-5555-666666666666",
                "image": "ghcr.io/pterodactyl/yolks:nodejs_18",
                "startup": "if [[ -d .git ]] && [[ {{AUTO_UPDATE}} == \"1\" ]]; then git pull; fi; if [[ ! -z ${NODE_PACKAGES} ]]; then /usr/local/bin/npm install ${NODE_PACKAGES}; fi; if [[ ! -z ${UNNODE_PACKAGES} ]]; then /usr/local/bin/npm uninstall ${UNNODE_PACKAGES}; fi; if [ -f /home/container/package.json ]; then /usr/local/bin/npm install; fi; /usr/local/bin/node /home/container/{{USER_UPLOAD_FILE}}",
                "memory_overhead": 0,
                "io_weight": 500,
                "environment": {
                    "USER_UPLOAD_FILE": "index.js",
                    "AUTO_UPDATE": "0"
                },
                "feature_limits": {
                    "allocations": 0,
                    "databases": 0,
                    "backups": 1,
                    "schedules": 0
                }
            }
        }
    },
    "location_comment": "Required. Auto-detect is disabled. You must configure nodes manually here.",
    "locations": {
        "node-1": {
            "name": "Singapore Node 1",
            "node_uuid": "aaaaaaaa-bbbb-cccc-dddd-eeeeeeeeeeee",
            "limit": 50
        },
        "node-2": {
            "name": "Germany Node 2",
            "node_uuid": "bbbbbbbb-cccc-dddd-eeee-ffffffffffff",
            "limit": -1
        }
    },
    "afk": {
        "enable": true,
        "coinPerStage": 10,
        "stageTime": 60
    },
    "store": {
        "enable": true,
        "cpu": [100, 100],
        "disk": [200, 1024],
        "ram": [250, 1024],
        "slot": [1500, 1],
        "_comment": "[price, amount(int)]"
    }
}
